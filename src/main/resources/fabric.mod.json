{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": ["Tim Waldin", "FloydAddons contributors"],
  "icon": "assets/floydaddons/icons/taskbar_icon_128x128.png",
  "license": "BSD-3-Clause AND MIT",
  "environment": "client",
  "entrypoints": {
    "modmenu": [
      "gg.floyd.clickgui.ModMenuIntegration"
    ],
    "client": [
      {
        "adapter": "kotlin",
        "value": "gg.floyd.FloydAddonsMod"
      }
    ]
  },
  "mixins": [
    "floydaddons.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": ">=${fabric_api_version}",
    "minecraft": "~${minecraft_version}",
    "fabric-language-kotlin": ">=${fabric_kotlin_version}"
  }
}
